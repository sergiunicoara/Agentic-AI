{
  "title": "AI-Native Data Platform — Overview",
  "description": "RAG platform: request traffic, pipeline latency, SLO rolling window, anomaly detection, reliability violations, generation health, ingestion.",
  "uid": "ai-platform-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {"list": []},
  "annotations": {"list": []},
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Request Traffic",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate (rps) — all routes",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {"tooltip": {"mode": "multi"}}
    },

    {
      "id": 3,
      "type": "timeseries",
      "title": "/ask Latency — p50 / p95 / p99 (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_latency_seconds_bucket{route=\"/ask\"}[5m])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_latency_seconds_bucket{route=\"/ask\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_latency_seconds_bucket{route=\"/ask\"}[5m])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {"lineWidth": 2, "fillOpacity": 5},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 900}
            ]
          }
        }
      },
      "options": {"tooltip": {"mode": "multi"}}
    },

    {
      "id": 4,
      "type": "timeseries",
      "title": "Error Rate by Route (5xx)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{status=~\"5..\"}[5m])) / sum by (route) (rate(http_requests_total[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Rate-Limited Requests (429)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{status=\"429\"}[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      }
    },

    {
      "id": 10,
      "type": "row",
      "title": "Pipeline Latency",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17},
      "collapsed": false
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Retrieval Latency — p50 / p95 (ms)",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(retrieval_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(retrieval_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms", "custom": {"lineWidth": 2}}}
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "Generation Latency — p50 / p95 (ms)",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(generation_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(generation_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms", "custom": {"lineWidth": 2}}}
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "Ingest Latency — p50 / p95 (ms)",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ingest_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ingest_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms", "custom": {"lineWidth": 2}}}
    },

    {
      "id": 20,
      "type": "row",
      "title": "SLO Rolling Window",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 26},
      "collapsed": false
    },

    {
      "id": 21,
      "type": "stat",
      "title": "Rolling p95 Latency (ms)",
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 27},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "slo_rolling_p95_latency_ms", "legendFormat": "p95", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 900}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    },

    {
      "id": 22,
      "type": "stat",
      "title": "Rolling Error Rate",
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 27},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "slo_rolling_error_rate", "legendFormat": "error rate", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.25}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    },

    {
      "id": 23,
      "type": "stat",
      "title": "Rolling Unknown Rate",
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 27},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "slo_rolling_unknown_rate", "legendFormat": "unknown rate", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.15},
              {"color": "red", "value": 0.35}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    },

    {
      "id": 30,
      "type": "row",
      "title": "Anomaly Detection (EWMA z-score)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "collapsed": false
    },

    {
      "id": 31,
      "type": "timeseries",
      "title": "Anomaly Scores — latency / error / unknown (z-score, alert threshold = 6)",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 33},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "platform_anomaly_score{signal=\"p95_latency_ms\"}",
          "legendFormat": "latency z-score",
          "refId": "A"
        },
        {
          "expr": "platform_anomaly_score{signal=\"error_rate\"}",
          "legendFormat": "error rate z-score",
          "refId": "B"
        },
        {
          "expr": "platform_anomaly_score{signal=\"unknown_rate\"}",
          "legendFormat": "unknown rate z-score",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {"lineWidth": 2, "fillOpacity": 5},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 4},
              {"color": "red", "value": 6}
            ]
          }
        }
      },
      "options": {"tooltip": {"mode": "multi"}},
      "thresholds": {
        "color": "red",
        "value": 6
      }
    },

    {
      "id": 40,
      "type": "row",
      "title": "Reliability & Generation",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 41},
      "collapsed": false
    },

    {
      "id": 41,
      "type": "timeseries",
      "title": "Reliability Contract Violations — by type",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 42},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (type) (rate(reliability_violations_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      }
    },

    {
      "id": 42,
      "type": "timeseries",
      "title": "Generation Failures — by error code",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 42},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (code) (rate(generation_failures_total[5m]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      }
    },

    {
      "id": 50,
      "type": "row",
      "title": "Ingestion",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 50},
      "collapsed": false
    },

    {
      "id": 51,
      "type": "timeseries",
      "title": "Ingest Jobs — by status (rps)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 51},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (status) (rate(ingest_jobs_total[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      }
    },

    {
      "id": 52,
      "type": "stat",
      "title": "Total Ingest Jobs (all time)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 51},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (status) (ingest_jobs_total)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [{"color": "blue", "value": null}]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "orientation": "horizontal"
      }
    }

  ]
}
